# --- Application ---
NODE_ENV="development"
PORT=3001
APP_NAME="Pode-Deixar"
FRONTEND_URL="http://localhost:3000"


# --- JWT ---
# Secrets
JWT_ACCESS_SECRET="CHANGE_THIS_TO_YOUR_JWT_ACCESS_SECRET"
JWT_REFRESH_SECRET="CHANGE_THIS_TO_YOUR_JWT_REFRESH_SECRET"

# Expiracy times
JWT_ACCESS_EXPIRES_IN=
JWT_REFRESH_EXPIRES_IN=


# --- Email Sender Configuration (Mailtrap Email Testing) ---
# Mailtrap → Email Testing → Inboxes → Integrations → SMTP
SMTP_HOST="sandbox.smtp.mailtrap.io"
SMTP_PORT=587
SMTP_USER="CHANGE_THIS_TO_YOUR_MAILTRAP_SMTP_USERNAME"
SMTP_PASS="CHANGE_THIS_TO_YOUR_MAILTRAP_SMTP_PASSWORD"
SMTP_FROM="noreply@podedeixar.com"


# --- Database ---

# Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="CHANGE_THIS_TO_YOUR_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="CHANGE_THIS_TO_YOUR_SERVICE_ROLE_KEY"

# --- Docker Compose Database Configuration ---
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="root"
POSTGRES_DB="auth_db"
POSTGRES_PORT=5432

# PGAdmin Configuration
PGADMIN_EMAIL="admin@admin.com"
PGADMIN_PASSWORD="admin"
PGADMIN_PORT=5051


# --- Security ---
# Login protection
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
ALLOWED_ORIGINS="http://localhost:3000"


# --- Logging ---
LOG_LEVEL=debug
LOG_ROTATE=true
LOG_DATE_PATTERN=YYYY-MM-DD
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d