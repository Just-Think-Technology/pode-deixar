{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2021",
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@pode-deixar/logger": ["../../shared/logger/dist"],
      "@pode-deixar/logger/*": ["../../shared/logger/dist/*"],
      "@pode-deixar/email": ["../../shared/email/dist"],
      "@pode-deixar/email/*": ["../../shared/email/dist/*"]
    }
  },
  "include": ["src/**/*.ts"]
}