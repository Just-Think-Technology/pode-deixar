{
  "name": "@pode-deixar/backend",
  "version": "1.0.0",
  "packageManager": "pnpm@11.9.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "pnpm run start:dev --filter @pode-deixar/auth",
    "dev:all": "concurrently \"pnpm run start:dev --filter @pode-deixar/auth\" \"pnpm run start:dev --filter @pode-deixar/users\"",
    "build": "pnpm run prisma:generate && pnpm run build --filter @pode-deixar/auth && pnpm run build --filter @pode-deixar/users",
    "start": "pnpm run start --filter @pode-deixar/auth",
    "start:all": "concurrently \"pnpm run start --filter @pode-deixar/auth\" \"pnpm run start --filter @pode-deixar/users\"",
    "start:prod": "pnpm run start:prod --filter @pode-deixar/auth",
    "test": "pnpm run test --filter @pode-deixar/auth && pnpm run test --filter @pode-deixar/users",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema=prisma/schema.prisma",
    "lint": "pnpm run lint --filter @pode-deixar/auth && pnpm run lint --filter @pode-deixar/users",
    "proxy:run": "powershell -File scripts/proxy.ps1 run",
    "proxy:start": "powershell -File scripts/proxy.ps1 start",
    "proxy:stop": "powershell -File scripts/proxy.ps1 stop"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "workspaces": [
    "shared/*",
    "services/*"
  ],
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "prisma": "5.22.0"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "pino": "^8.18.0",
    "pino-pretty": "^10.0.0"
  }
}
